# Copy to .env and fill in.

# Public address clients dial in to. Use your TP-Link DDNS hostname (recommended,
# since home IPs change) or your public IP. On a LAN-only test box, the LAN IP works
# just to bring it up.
WG_HOST=yourname.tplinkdns.com

# Web UI password, as a bcrypt hash. Generate it (note the SINGLE quotes it prints):
#   docker run --rm ghcr.io/wg-easy/wg-easy:14 wgpw 'YourStrongPassword'
# Paste the hash here WITHOUT quotes. env_file passes it literally, so leave the $ as-is.
PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# Public UDP port advertised in client configs (must match the router port-forward).
WG_PORT=51820

# VPN client address pool (its own subnet, unrelated to your LAN).
WG_DEFAULT_ADDRESS=10.8.0.x

# DNS pushed to connected clients = Pi-hole. This is what makes *.lan resolve and
# ad-blocking work over the tunnel. Set to the homeserver's LAN IP.
WG_DEFAULT_DNS=192.168.0.201

# SPLIT TUNNEL: only this subnet is routed through the VPN (your home LAN). Everything
# else stays on the client's normal connection, so a homeserver outage never breaks the
# client's internet. Set to your homeserver's LAN subnet.
#   Full tunnel (route ALL traffic) would be: 0.0.0.0/0, ::/0  -- not recommended here.
WG_ALLOWED_IPS=192.168.0.0/24

# Keep NAT mappings alive (helps phones behind CGNAT).
WG_PERSISTENT_KEEPALIVE=25
