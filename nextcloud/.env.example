# Copy to .env and fill in. Use strong, unique values: openssl rand -base64 32
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=change-me-db
REDIS_PASSWORD=change-me-redis

NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=change-me-admin

# All hostnames/IPs you'll use to reach it, space separated.
NC_TRUSTED_DOMAINS=192.168.0.150 cloud.lan
# CIDR of your reverse proxy / docker network so client IPs are read correctly.
NC_TRUSTED_PROXIES=172.16.0.0/12

NC_HTTP_PORT=8081
