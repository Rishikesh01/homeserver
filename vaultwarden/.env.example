# Copy to .env and fill in. Never commit the real .env.
VW_DOMAIN=https://vault.example.com
# Long random string. Generate: openssl rand -base64 48
VW_ADMIN_TOKEN=change-me-long-random-string
# Set to false after you create your account to lock down registrations.
VW_SIGNUPS_ALLOWED=true
# Host port. Default 8082 (not 8080) because this server already runs Kubernetes,
# which holds 8080. Pick any free port if 8082 is taken — keep caddy's VAULT_UPSTREAM in sync.
VW_HTTP_PORT=8082
