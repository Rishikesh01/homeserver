# Copy to .env and fill in. Never commit the real .env.
VW_DOMAIN=https://vault.example.com
# /admin panel token. hsctl stores this as an Argon2id HASH (not plaintext) so the raw
# token never touches disk — set/rotate it with: hsctl secrets rotate-vw-admin
# If editing by hand: put an Argon2 PHC string here, and DOUBLE every '$' to '$$' (so
# docker-compose's ${VAR} interpolation passes it through). Leave blank to disable /admin.
VW_ADMIN_TOKEN=
# Set to false after you create your account to lock down registrations.
VW_SIGNUPS_ALLOWED=true
# Host port. hsctl auto-picks the next free port from 8080 (e.g. if something else —
# like a k8s service — already holds 8080). Keep caddy's VAULT_UPSTREAM in sync.
VW_HTTP_PORT=8080
