# Copy to .env and fill in. Never commit the real .env.
VW_DOMAIN=https://vault.example.com
# Long random string. Generate: openssl rand -base64 48
VW_ADMIN_TOKEN=change-me-long-random-string
# Set to false after you create your account to lock down registrations.
VW_SIGNUPS_ALLOWED=true
# Host port. bootstrap.sh auto-picks the next free port from 8080 (e.g. if something
# else — like a k8s service — already holds 8080). Keep caddy's VAULT_UPSTREAM in sync.
VW_HTTP_PORT=8080
