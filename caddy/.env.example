# Copy to .env and fill in.

# Hostnames you'll use to reach each service. For a LAN-only setup these can be
# anything (e.g. *.lan) as long as your devices resolve them to this server's IP
# (via Pi-hole "Local DNS", your router, or /etc/hosts).
VAULT_HOST=vault.lan
CLOUD_HOST=cloud.lan
PIHOLE_HOST=pihole.lan
HOME_HOST=home.lan

# TLS mode:
#   "tls internal"  -> Caddy issues certs from its own local CA (works offline on
#                      LAN; install the CA root on your devices to avoid warnings).
#   ""  (empty)     -> automatic Let's Encrypt. Requires the hostnames to be REAL
#                      public domains pointing here, with ports 80+443 reachable
#                      from the internet (or use the DNS-01 challenge).
TLS_DIRECTIVE=tls internal

# Only used for Let's Encrypt.
ACME_EMAIL=you@example.com

# Where Caddy forwards each hostname. These are the published host ports of the
# three stacks, reached via the docker host gateway.
VAULT_UPSTREAM=host.docker.internal:8080
CLOUD_UPSTREAM=host.docker.internal:8081
PIHOLE_UPSTREAM=host.docker.internal:8053
# The hsctl web UI running on the host (bind it to :8088 so Caddy's gateway can reach it).
HOME_UPSTREAM=host.docker.internal:8088

# Plain-HTTP addresses that serve the local root CA for easy device import (browse
# one of these on a new device to install the cert). Include the server IP so it
# works even before the device uses Pi-hole DNS. Space-separated Caddy site addresses.
CA_HOSTS=http://ca.lan http://192.168.1.10
