# Copy to .env and fill in (hsctl setup generates this for you).

# This server's LAN IP — used as the cert SAN so https://<ip>:<port> is trusted
# (Caddy's local CA, installed once per device). No hostnames/TLD are used.
SERVER_IP=192.168.1.10

# Only used if you ever switch to a real public domain + Let's Encrypt.
ACME_EMAIL=you@example.com

# Where Caddy forwards each app — the published host ports, via the docker host gateway.
VAULT_UPSTREAM=host.docker.internal:8080
CLOUD_UPSTREAM=host.docker.internal:8081
PIHOLE_UPSTREAM=host.docker.internal:8053
# The hsctl web UI running on the host (bind it to :8088 so Caddy's gateway can reach it).
HOME_UPSTREAM=host.docker.internal:8088

# HTTPS ports each app is exposed on (https://SERVER_IP:PORT). Must match services.json
# (the dashboard) so its tiles link to the right place.
VAULT_HTTPS=8443
CLOUD_HTTPS=8444
PIHOLE_HTTPS=8445
HOME_HTTPS=8446
