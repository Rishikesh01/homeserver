{
	# Used only if you ever switch to a real public domain.
	email {$ACME_EMAIL}
	# Browsers don't send SNI for a bare IP, so without this the handshake fails with
	# "no SNI". Make the server IP the default so the IP cert is served regardless.
	default_sni {$SERVER_IP}
	# Don't auto-redirect HTTP->HTTPS: we serve the CA download on plain :80.
	auto_https disable_redirects
}

# --- Plain HTTP: serve the local root CA so devices can install it ---
# A device that doesn't trust the CA yet can't use HTTPS, so this is on port 80.
# Serves only the public root cert. Browse http://<server>/ to install it.
:80 {
	handle /root.crt {
		root * /data/caddy/pki/authorities/local
		file_server
		header Content-Type "application/x-x509-ca-cert"
	}
	handle {
		header Content-Type "text/html; charset=utf-8"
		respond `<!doctype html><meta name=viewport content="width=device-width,initial-scale=1"><title>Home server</title><h1>Home server</h1><p>Install the <a href="/root.crt"><b>certificate</b></a> once on this device, then open the dashboard.</p>` 200
	}
}

# --- Each app over HTTPS at the server IP + its own port ---
# The site address is <ip>:<port> so "tls internal" mints a cert with the server IP
# in the SAN (trusted once the CA above is installed). `bind 0.0.0.0` makes Caddy
# actually listen on all of the container's interfaces (it has no <ip> of its own).

{$SERVER_IP}:{$VAULT_HTTPS} {
	bind 0.0.0.0
	tls internal
	reverse_proxy {$VAULT_UPSTREAM}
}

{$SERVER_IP}:{$CLOUD_HTTPS} {
	bind 0.0.0.0
	tls internal
	reverse_proxy {$CLOUD_UPSTREAM}
	redir /.well-known/carddav /remote.php/dav 301
	redir /.well-known/caldav /remote.php/dav 301
	redir /.well-known/webfinger /index.php/.well-known/webfinger 301
	redir /.well-known/nodeinfo /index.php/.well-known/nodeinfo 301
	header {
		Strict-Transport-Security "max-age=15552000; includeSubDomains"
	}
}

{$SERVER_IP}:{$PIHOLE_HTTPS} {
	bind 0.0.0.0
	tls internal
	redir / /admin/ 302
	reverse_proxy {$PIHOLE_UPSTREAM}
}

# The hsctl dashboard — the home page for all services.
{$SERVER_IP}:{$HOME_HTTPS} {
	bind 0.0.0.0
	tls internal
	reverse_proxy {$HOME_UPSTREAM}
}

# --- Web tools ---
{$SERVER_IP}:{$STIRLING_HTTPS} {
	bind 0.0.0.0
	tls internal
	reverse_proxy {$STIRLING_UPSTREAM}
}

{$SERVER_IP}:{$ITTOOLS_HTTPS} {
	bind 0.0.0.0
	tls internal
	reverse_proxy {$ITTOOLS_UPSTREAM}
}

{$SERVER_IP}:{$IMAGETOOLS_HTTPS} {
	bind 0.0.0.0
	tls internal
	reverse_proxy {$IMAGETOOLS_UPSTREAM}
}
