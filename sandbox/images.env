# Image manifest for the test sandbox.
#
# This is the list of images the sandbox brings up. To try a NEW version of a
# service before touching your live system, change its tag here and run:
#
#     make sandbox            # (re)build + start the sandbox with these images
#     make sandbox-restore    # optionally restore your real data into it
#
# then open the apps via the sandbox and confirm the new version behaves. Only
# once you're happy do you change the real <service>/docker-compose.yml.
#
# Format: <component>=<image:tag>   (component names are fixed; see the table below)
# Point the sandbox at a different manifest with:  make sandbox IMAGES=path/to/file
#
# Defaults below mirror the current live tags (kept in sync by hand).

vaultwarden=vaultwarden/server:1.36.0
nextcloud-db=postgres:16-alpine
nextcloud-redis=redis:7-alpine
nextcloud-app=nextcloud:30-apache
pihole=pihole/pihole:2025.04.0
caddy=caddy:2.8-alpine
stirling-pdf=ghcr.io/stirling-tools/stirling-pdf:2.12.0
it-tools=ghcr.io/corentinth/it-tools:2024.10.22-7ca5933
imagetools=nginx:1.27-alpine
