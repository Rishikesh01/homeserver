# Image overrides for the test sandbox.
#
# By default this file is EMPTY of active entries, so the sandbox brings up exactly the
# image tags pinned in each service's own docker-compose.yml — the single source of truth,
# so there's nothing here to keep in sync.
#
# To try a NEW version of a service before touching your live system, uncomment its line
# below (or add one) with the tag you want to test, then:
#
#     make sandbox            # (re)build + start the sandbox with these images
#     make sandbox-restore    # optionally restore your real data into it
#
# open the apps via the sandbox, confirm the new version behaves, and only then bump the
# tag in the real <service>/docker-compose.yml. Point at a different file with:
#     make sandbox IMAGES=path/to/file
#
# Format: <component>=<image:tag>   (component names are fixed; left side of each example).

#vaultwarden=vaultwarden/server:1.37.0
#nextcloud-db=postgres:16-alpine
#nextcloud-redis=redis:7-alpine
#nextcloud-app=nextcloud:31-apache
#pihole=pihole/pihole:2025.04.0
#caddy=caddy:2.8-alpine
#stirling-pdf=ghcr.io/stirling-tools/stirling-pdf:2.12.0
#it-tools=ghcr.io/corentinth/it-tools:2024.10.22-7ca5933
#imagetools=nginx:1.27-alpine
