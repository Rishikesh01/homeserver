# Copy to .env and fill in.
TZ=Asia/Kolkata
# Admin panel password.
PIHOLE_PASSWORD=change-me-strong
# Upstream DNS servers, semicolon separated.
PIHOLE_UPSTREAMS=1.1.1.1;9.9.9.9
# Host port for the web UI (container :80). Kept off 80 to avoid clashing with other services.
PIHOLE_WEB_PORT=8053
# Host IP to bind DNS (:53) to. This host runs systemd-resolved, whose stub already
# holds :53 (on 127.0.0.53/127.0.0.54), so binding 0.0.0.0 would clash — Pi-hole is
# pinned to this server's LAN IP instead. Update it if the LAN IP changes. (On a host
# with :53 free, you can set this to 0.0.0.0 to serve every interface.)
PIHOLE_DNS_BIND=192.168.0.150
