# Copy to .env and fill in.
TZ=Etc/UTC
# Admin panel password.
PIHOLE_PASSWORD=change-me-strong
# Upstream DNS servers, semicolon separated.
PIHOLE_UPSTREAMS=1.1.1.1;9.9.9.9
# Host port for the web UI (container :80). Kept off 80 to avoid clashing with other services.
PIHOLE_WEB_PORT=8053
# Host IP to bind DNS (:53) to. 0.0.0.0 = all interfaces (serve the whole LAN). If
# another resolver already holds :53 (systemd-resolved's stub, or libvirt/LXC dnsmasq),
# set this to the server's LAN IP instead so the binds don't clash. bootstrap.sh
# auto-detects which to use.
PIHOLE_DNS_BIND=0.0.0.0
