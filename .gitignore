# Never commit real secrets — only the .env.example templates.
.env
**/.env

# Generated, environment-specific artifacts (comments MUST be on their own lines —
# gitignore treats a trailing "# ..." as part of the pattern).

# human logins printed by bootstrap.sh
.secrets.txt
# extracted per-host CA cert (regenerate with ./get-ca.sh)
caddy-root-ca.crt
# generated from custom.list.example by bootstrap.sh
pihole/custom.list
# your saved answers / personalized handout (settings, not secrets — still per-host)
setup.conf
WELCOME.txt
# hsctl: compiled binary + web-UI admin password
hsctl/hsctl
.ui-password
# backups: destination config, restic repo password, local snapshots/staging
backup.conf
.restic-password
backups/
