# Never commit real secrets — only the .env.example templates.
.env
**/.env

# Generated, environment-specific artifacts (comments MUST be on their own lines —
# gitignore treats a trailing "# ..." as part of the pattern).

# human logins printed by hsctl setup
.secrets.txt
# extracted per-host CA cert (regenerate with hsctl get-ca)
caddy-root-ca.crt
# generated by hsctl setup
pihole/custom.list
# your saved answers / personalized handout (settings, not secrets — still per-host)
setup.conf
WELCOME.txt
# hsctl: compiled binary + web-UI admin password
hsctl/hsctl
.ui-password
# backups: destination config, restic repo password, local snapshots/staging
backup.conf
.restic-password
backups/
# restore extraction dir (transient, root-owned)
restore/

# cloud migration: provider creds, Tailscale auth key, per-host migration state + ssh keys
# (NEVER commit — these hold provider tokens, the tailnet key, and host-specific authority).
cloud.conf
cloud/
.tailscale-authkey
cloud-state
migration.state
migration.lock
migration.log
known_hosts_home
id_restic
id_restic.pub
