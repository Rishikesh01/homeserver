# Example configuration for hsctl.
#
# You normally DON'T create this by hand — `hsctl setup` prompts for each value and writes
# setup.conf for you. Copy this to setup.conf only to pre-seed an unattended
# `hsctl setup --yes` run. These are settings, not secrets (secrets go into each .env).
# setup.conf is gitignored.

SERVER_IP=192.168.1.10          # this host's LAN IP (hsctl autodetects it)
TZ_VAL=Etc/UTC                  # e.g. Europe/Brussels, Asia/Kolkata
ACME_EMAIL=you@example.com      # only used if you ever switch to a real domain + Let's Encrypt
VW_HTTP_PORT=8080               # Vaultwarden host port (hsctl bumps it if already in use)
NC_HTTP_PORT=8081               # Nextcloud host port
PIHOLE_WEB_PORT=8053            # Pi-hole web port
UI_PORT=8088                    # hsctl dashboard port (Caddy proxies it at https://SERVER_IP)
PIHOLE_DNS_BIND=0.0.0.0         # set to SERVER_IP if another resolver already holds :53
VW_SIGNUPS_ALLOWED=true         # false = invitation-only
